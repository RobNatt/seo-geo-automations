# Local: copy to .env (never commit .env)
DATABASE_URL="file:./dev.db"
# Vercel / serverless: use a hosted DB (Turso, Neon, Vercel Postgres, etc.). A file: SQLite URL is not
# reliable — the instance that runs the onboard action may not be the same one that serves /sites/[id].

# Optional — token → siteId map for /report/<token> and /portal/<token>
# CLIENT_REPORT_TOKENS_JSON='{"your-secret-token":"clxxxxxxxxsiteid"}'

# Optional — report layout brand (server-only)
# CLIENT_REPORT_BRAND_NAME="Your agency name"

# Optional — client portal product shell (browser-safe)
# NEXT_PUBLIC_PORTAL_PRODUCT_NAME="Program portal"
# NEXT_PUBLIC_PORTAL_OFFERING_TAGLINE="Status, reports, and next steps."
# NEXT_PUBLIC_PORTAL_SUPPORT_CONTACT="Email or link for support."
